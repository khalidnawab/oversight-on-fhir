<https://oversight-on-fhir.org/fhir/ImplementationGuide/oversight-on-fhir> a fhir:ImplementationGuide ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:Resource.id [ fhir:value "oversight-on-fhir"] ;
  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "generated" ] ;
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ImplementationGuide oversight-on-fhir</b></p><a name=\"oversight-on-fhir\"> </a><a name=\"hcoversight-on-fhir\"> </a><h2>OversightOnFHIR</h2><p>The official URL for this implementation guide is: </p><pre>https://oversight-on-fhir.org/fhir/ImplementationGuide/oversight-on-fhir</pre><div><p>A draft IG representing the human oversight decision over agentic clinical AI output as first-class FHIR resources. Complementary to the HL7 AI Transparency on FHIR IG: that effort represents AI influence on clinical data; this profile represents the human decision (accept/edit/reject, with a structured reason) over agentic AI output.</p>\n</div></div>"
  ] ;
  fhir:ImplementationGuide.url [ fhir:value "https://oversight-on-fhir.org/fhir/ImplementationGuide/oversight-on-fhir"] ;
