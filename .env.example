# FHIR server the client reads/writes. Local HAPI by default.
OVERSIGHT_FHIR_BASE_URL=http://localhost:8080/fhir
# Bearer token for SMART-on-FHIR; blank for an open local server (Section 6).
OVERSIGHT_FHIR_BEARER_TOKEN=
# Inference backend: "frontier" or "local".
OVERSIGHT_BACKEND=frontier
# HARD SAFETY GATE: frontier backend refuses to run unless this is true (Section 4.9).
OVERSIGHT_SYNTHETIC_DATA_ONLY=true
# Frontier model id (Section 14 — Device metadata / model identity).
OVERSIGHT_MODEL=claude-opus-4-8
# Anthropic API key for the frontier backend. Put your real key in .env (gitignored), never here.
ANTHROPIC_API_KEY=
# Routing confidence threshold (Section 9.2 / Section 14). Below this => escalate.
OVERSIGHT_CONFIDENCE_THRESHOLD=0.7
