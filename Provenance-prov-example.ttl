# - resource -------------------------------------------------------------------

<https://oversight-on-fhir.org/fhir/Provenance/prov-example> a fhir:Provenance ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:Resource.id [ fhir:value "prov-example"] ;
  fhir:Resource.meta [
     fhir:Meta.profile [
       fhir:value "https://oversight-on-fhir.org/fhir/StructureDefinition/ai-authorship-provenance" ;
       fhir:index 0 ;
       fhir:link <https://oversight-on-fhir.org/fhir/StructureDefinition/ai-authorship-provenance>
     ]
  ] ;
  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "generated" ] ;
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: Provenance prov-example</b></p><a name=\"prov-example\"> </a><a name=\"hcprov-example\"> </a><div style=\"display: inline-block; background-color: #d9e0e7; padding: 6px; margin: 4px; border: 1px solid #8da1b4; border-radius: 5px; line-height: 60%\"><p style=\"margin-bottom: 0px\"/><p style=\"margin-bottom: 0px\">Profile: <a href=\"StructureDefinition-ai-authorship-provenance.html\">AI Authorship Provenance</a></p></div><p>Provenance for <a href=\"GuidanceResponse-gr-example.html\">GuidanceResponse: module[x] = ; status = success; occurrenceDateTime = 2026-07-10 12:00:00+0000; note = This recommendation was generated by an AI system and requires clinician review.</a></p><p>Summary</p><table class=\"grid\"><tr><td>Recorded</td><td>2026-07-10 12:00:00+0000</td></tr><tr><td>Activity</td><td><span title=\"Codes:{http://terminology.hl7.org/CodeSystem/v3-DataOperation CREATE}\">machine-generated</span></td></tr></table><p><b>Agents</b></p><table class=\"grid\"><tr><td><b>Type</b></td><td><b>who</b></td></tr><tr><td><span title=\"Codes:{http://terminology.hl7.org/CodeSystem/provenance-participant-type author}\">Author</span></td><td><a href=\"Device-oversight-ai.html\">Device: status = active</a></td></tr></table></div>"
  ] ;
  fhir:Provenance.target [
     fhir:index 0 ;
     fhir:link <https://oversight-on-fhir.org/fhir/GuidanceResponse/gr-example> ;
     fhir:Reference.reference [ fhir:value "GuidanceResponse/gr-example" ]
  ] ;
  fhir:Provenance.recorded [ fhir:value "2026-07-10T12:00:00Z"^^xsd:dateTime] ;
  fhir:Provenance.activity [
     fhir:CodeableConcept.coding [
       fhir:index 0 ;
       fhir:Coding.system [ fhir:value "http://terminology.hl7.org/CodeSystem/v3-DataOperation" ] ;
       fhir:Coding.code [ fhir:value "CREATE" ] ;
       fhir:Coding.display [ fhir:value "create" ]
     ] ;
     fhir:CodeableConcept.text [ fhir:value "machine-generated" ]
  ] ;
  fhir:Provenance.agent [
     fhir:index 0 ;
     fhir:Provenance.agent.type [
       fhir:CodeableConcept.coding [
         fhir:index 0 ;
         fhir:Coding.system [ fhir:value "http://terminology.hl7.org/CodeSystem/provenance-participant-type" ] ;
         fhir:Coding.code [ fhir:value "author" ]
       ]
     ] ;
     fhir:Provenance.agent.who [
       fhir:link <https://oversight-on-fhir.org/fhir/Device/oversight-ai> ;
       fhir:Reference.reference [ fhir:value "Device/oversight-ai" ]
     ]
  ] .

